# ─────────────────────────────────────────────────────────────────────────────
# InvestiGate — environment configuration
#
# Copy this file to .env and fill in the values you need.
#   cp .env.example .env
#
# The default configuration uses local Ollama — no API keys required.
# ─────────────────────────────────────────────────────────────────────────────


# ── LLM Provider ─────────────────────────────────────────────────────────────
# Options: ollama | anthropic | openai | mixed
#   ollama     → all agents run on your local Ollama instance (no API key needed)
#   anthropic  → all agents use Claude (requires ANTHROPIC_API_KEY)
#   openai     → all agents use GPT-4o (requires OPENAI_API_KEY)
#   mixed      → analysts use Claude, judge uses GPT-4o (requires both keys)
LLM_PROVIDER=ollama


# ── Ollama settings (used when LLM_PROVIDER=ollama) ──────────────────────────
# URL of your local Ollama server
OLLAMA_BASE_URL=http://localhost:11434

# Model used by the Bull, Bear, and Strategist analysts
ANALYST_MODEL=llama3.1

# Model used by the Judge (final recommendation)
JUDGE_MODEL=llama3.1

# Embedding model for RAG document retrieval (Ollama)
EMBEDDING_MODEL=nomic-embed-text


# ── API Keys (only needed for non-Ollama providers) ──────────────────────────
# Required when LLM_PROVIDER=anthropic or mixed
# ANTHROPIC_API_KEY=sk-ant-...

# Required when LLM_PROVIDER=openai or mixed
# OPENAI_API_KEY=sk-...

# Optional: enables Whisper transcription + GPT-4o-mini intent parsing for voice input
# Without this, voice input falls back to local regex parsing
# OPENAI_API_KEY=sk-...


# ── LLM Tuning ───────────────────────────────────────────────────────────────
# Sampling temperature for all agents (0.0 = deterministic, 1.0 = creative)
LLM_TEMPERATURE=0.3


# ── RAG (Retrieval-Augmented Generation) ─────────────────────────────────────
# Enable/disable fetching SEC filings and news articles before analysis
RAG_ENABLED=true

# How long to cache fetched documents before re-fetching (hours)
RAG_TTL_HOURS=24

# Directory where ChromaDB vector store is persisted
CHROMA_PERSIST_DIR=./chroma_db


# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default) — no setup required
DATABASE_URL=sqlite:///./investigateai.db

# PostgreSQL example (optional, for production use)
# DATABASE_URL=postgresql://user:password@localhost:5432/investigateai


# ── Frontend ─────────────────────────────────────────────────────────────────
# Backend URL used by the Vite dev server
# (override if your backend runs on a different host/port)
VITE_API_URL=http://localhost:8000
