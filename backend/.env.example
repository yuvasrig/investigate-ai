# ─────────────────────────────────────────────────────────────────────────────
# InvestiGate Backend — Environment Configuration
# Copy to .env and fill in values for your chosen provider.
# ─────────────────────────────────────────────────────────────────────────────

# ── Provider selection ────────────────────────────────────────────────────────
# Controls which LLM(s) run the agents.
#
#   ollama     → all agents use a local Ollama model (free, no API key needed)
#   anthropic  → all agents use Claude (ANTHROPIC_API_KEY required)
#   openai     → all agents use GPT-4o (OPENAI_API_KEY required)
#   mixed      → analysts use Claude, judge uses GPT-4o (both keys required)
#                This is the default and highest quality option.
#
LLM_PROVIDER=mixed

# ── Model overrides (optional) ────────────────────────────────────────────────
# Defaults are set per-provider in config.py. Override only if needed.
#
# ANALYST_MODEL=claude-sonnet-4-6
# JUDGE_MODEL=gpt-4o

# ── Temperature ───────────────────────────────────────────────────────────────
# LLM_TEMPERATURE=0.3

# ── API Keys ──────────────────────────────────────────────────────────────────
# Only required for the provider(s) you are using.
#
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# ── Ollama (local development) ────────────────────────────────────────────────
# Set LLM_PROVIDER=ollama and ensure Ollama is running locally.
# Pull a model first:  ollama pull llama3.1
#
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1    (used as ANALYST_MODEL and JUDGE_MODEL when provider=ollama)

# ── RAG configuration ──────────────────────────────────────────────────────────
# RAG_ENABLED=true               Set to false to disable RAG entirely (grounding only)
# RAG_TTL_HOURS=24               How long indexed documents stay fresh before re-fetching
# CHROMA_PERSIST_DIR=./chroma_db Directory for ChromaDB vector store
# EMBEDDING_MODEL=text-embedding-3-small   Override the embedding model
#
# Embedding provider is chosen automatically from LLM_PROVIDER:
#   openai / mixed  → text-embedding-3-small (requires OPENAI_API_KEY)
#   ollama          → nomic-embed-text        (pull first: ollama pull nomic-embed-text)
#   anthropic-only  → text-embedding-3-small  (Anthropic has no embeddings API)
#   no key at all   → sentence-transformers   (fully local fallback, slower first run)

# ── Authentication (JWT) ───────────────────────────────────────────────────────
# Set AUTH_ENABLED=true to require login for protected endpoints (watchlists, alerts).
# Leave false for local development — all auth endpoints still work, guards are skipped.
#
# AUTH_ENABLED=false
# AUTH_SECRET_KEY=change-me-to-a-long-random-string-in-production
# AUTH_ALGORITHM=HS256
# AUTH_TOKEN_EXPIRE_HOURS=168    # 7 days

# ── Plaid Integration ─────────────────────────────────────────────────────────
# Plaid is optional. When configured, users can connect real brokerage accounts.
# Sign up at https://dashboard.plaid.com/ to get credentials.
#
# PLAID_CLIENT_ID=your_plaid_client_id
# PLAID_SECRET=your_plaid_sandbox_secret
# PLAID_ENV=sandbox    # sandbox | development | production

# ── Tax harvesting rates ───────────────────────────────────────────────────────
# Default US rates. Override for different jurisdictions or tax situations.
#
# TAX_SHORT_TERM_RATE=0.37    # Ordinary income tax rate (short-term gains < 1 year)
# TAX_LONG_TERM_RATE=0.20     # Long-term capital gains rate (> 1 year)
